{
  "name": "pebble-github-watcher",
  "author": "Tanner",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "@rebble/clay": "^1.0.10",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "scripts": {
    "test": "jest",
    "test:c": "bash test/c/run.sh",
    "test:all": "npm test && npm run test:c"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test/js"
    ]
  },
  "pebble": {
    "displayName": "GitHub Watcher",
    "uuid": "80918b9e-a444-40c7-8b60-fed47e97b7cf",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "MsgType",
      "Idx",
      "Count",
      "Label",
      "Status",
      "AgeS",
      "UserCode",
      "VerifyUrl",
      "Msg",
      "Size",
      "Data",
      "Ok",
      "Time",
      "Action",
      "RepoIdx",
      "Num",
      "Branch",
      "Sha",
      "Dur"
    ],
    "resources": {
      "media": []
    }
  }
}
